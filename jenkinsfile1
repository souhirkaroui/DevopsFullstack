pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        SONARQUBE_SERVER = 'SonarQube'
        EMAIL_TO = 'souhir.karoui.ks@gmail.com'
    }

    stages {

  /* =========================== BUILD ============================= */
        stage('Build Backend') {
            steps {
                script {
                    try {
                        dir('backend-souhir') {
                        sh 'mvn clean package -DskipTests=true'
                        notifyMail('Build', 'SUCCESS')
                    } catch (err) {
                        notifyMail('Build', 'FAILED')
                        error("Build failed")
                    }
                }
            }
        }
}
/* ============================= TEST =================================== */
        stage('Test Backend') {
            steps {
                script {
                    try {
                        dir('backend-souhir') {
                        sh 'mvn test package -DskipTests=true'
                        notifyMail('Test', 'SUCCESS')
                    } catch (err) {
                        notifyMail('Test', 'FAILED')
                        error("Tests failed")
                    }
                }
            }
        }
 } 
/* =========================== BUILD FRONTEND ============================= */    
     stage('Build Frontend') {
            steps {
            try {
                dir('frontend-souhir') {
                    sh 'npm install'
                    sh 'ng build --configuration production'
                    notifyMail('Build', 'SUCCESS')
                    } catch (err) {
                        notifyMail('Build', 'FAILED')
                        error("Build failed")
                      }
                   }
                }
            }
 /* =========================== TEST FRONTEND ============================= */         
        stage('TEST Frontend') {
            steps {
            try {
                dir('frontend-souhir') {
                    sh 'npm run test -- --watch=false --browsers=ChromeHeadless'
                    notifyMail('Test', 'SUCCESS')
                    } catch (err) {
                        notifyMail('Test', 'FAILED')
                        error("Tests failed")
                      }
                   }
                }
            }

 /* ======================= SONARQUBE + QUALITY GATE ================= */
        stage('SonarQube & Quality Gate') {
            steps {
                script {
                    try {
                        withSonarQubeEnv('SonarQube') {
                            withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                                            sh '''
                                                     mvn clean package -DskipTests sonar:sonar \
                                                     -Dsonar.projectKey=kubernetes \
                                                     -Dsonar.login=$SONAR_TOKEN
                                             '''
                                  }

                        }

                        timeout(time: 25, unit: 'MINUTES') {
                            waitForQualityGate abortPipeline: true
                        }

                        notifyMail('SonarQube & Quality Gate', 'SUCCESS')
                    } catch (err) {
                        notifyMail('SonarQube & Quality Gate', 'FAILED')
                        error("SonarQube & Quality Gate stage failed")
                    }
                }
            }
        }

        /* ================= NEXUS ================= */
        stage('Upload to Nexus') {
            steps {
                script {
                    try {
                        nexusArtifactUploader(
                            nexusVersion: 'nexus3',
                            protocol: 'http',
                            nexusUrl: '172.31.15.219:8081',
                            repository: 'compare-service',
                            credentialsId: 'Nexus',
                            groupId: 'com.devops',
                            version: "0.0.1-${BUILD_NUMBER}",
                            artifacts: [
                                [
                                    artifactId: 'numeric',
                                    classifier: '',
                                    file: 'target/numeric-0.0.1.jar',
                                    type: 'jar'
                                ]
                            ]
                        )
                        notifyMail('Upload to Nexus', 'SUCCESS')
                    } catch (err) {
                        notifyMail('Upload to Nexus', 'FAILED')
                        error("Nexus upload failed")
                    }
                }
            }
        }
/* ================= Continuous Integration frontend ============================ */
   
   stage('Docker Build & Push Frontend') {
    steps {
        script {
            try {

                withCredentials([usernamePassword(
                    credentialsId: 'DockerHub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    ansible-playbook playbookfront.yml \
                      --extra-vars "dockerhub_user=$DOCKER_USER dockerhub_password=$DOCKER_PASS"
                    '''
                }

                notifyMail('Build and push Frontend', 'SUCCESS')

            } catch (err) {

                notifyMail('Build and push', 'FAILED')
                error("Frontend Docker build failed")
            }
        }
    }
}
/* ================= Continuous Integration backend ========================== */
     stage('Docker Build & Push Backend') {
    steps {
        script {
            try {

                withCredentials([usernamePassword(
                    credentialsId: 'DockerHub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    ansible-playbook playbookback.yml \
                      --extra-vars "dockerhub_user=$DOCKER_USER dockerhub_password=$DOCKER_PASS"
                    '''
                }

                notifyMail('Docker Build & Push Backend', 'SUCCESS')

            } catch (err) {

                notifyMail('Docker Build & Push Backend', 'FAILED')
                error("Backend Docker build failed")
            }
        }
    }
}                               

/* ======================CONTINUOUS DEPLOY ============================= */
       stage('Deploy to Kubernetes') {
    steps {
        script {
            try {

                sh """
                    ansible-playbook -i inventory.yaml deploy-k8s.yaml \
                    -e image_tag=${BUILD_NUMBER}
                """

                notifyMail('Deploy to k8s', 'SUCCESS')

            } catch (err) {

                notifyMail('Deploy to k8s', 'FAILED')
                error("Deployment failed")

            }
        }
    }
}

    }

    post {
        success {
            notifyMail('PIPELINE GLOBAL', 'SUCCESS')
        }
        failure {
            notifyMail('PIPELINE GLOBAL', 'FAILED')
        }
    }
}
/* ================= PREMIUM EMAIL FUNCTION ================= */
