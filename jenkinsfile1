    def statusColor = (status == "SUCCESS") ? "#16a34a" : "#dc2626"
    def statusBg    = (status == "SUCCESS") ? "#dcfce7" : "#fee2e2"
    def statusIcon  = (status == "SUCCESS") ? "✅ SUCCESS" : "❌ FAILED"

    mail(
        to: "${env.EMAIL_TO}",
        subject: "🚀 [JENKINS] ${stageName} - ${status}",
        mimeType: 'text/html',
        body: """
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
</head>
<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0">
<tr>
<td align="center">

<table width="650" cellpadding="0" cellspacing="0" style="background:#ffffff;margin:40px auto;border-radius:10px;box-shadow:0 8px 20px rgba(0,0,0,0.1);overflow:hidden;">

<!-- HEADER -->
<tr>
<td style="background:linear-gradient(90deg,#0f172a,#1e3a8a);padding:25px;text-align:center;color:white;">
<h1 style="margin:0;font-size:22px;">🚀 DevOps CI/CD Pipeline</h1>
<p style="margin:5px 0 0 0;font-size:14px;opacity:0.8;">AWS • Docker • Kubernetes • Jenkins</p>
</td>
</tr>

<!-- STATUS BADGE -->
<tr>
<td align="center" style="padding:25px;">
<span style="background:${statusBg};color:${statusColor};padding:12px 25px;border-radius:30px;font-weight:bold;font-size:16px;">
${statusIcon}
</span>
<h2 style="margin-top:20px;color:#111827;">${stageName}</h2>
</td>
</tr>

<!-- DETAILS TABLE -->
<tr>
<td style="padding:0 40px 30px 40px;">
<table width="100%" cellpadding="10" cellspacing="0" style="border-collapse:collapse;font-size:14px;">

<tr style="background:#f9fafb;">
<td><strong>Project</strong></td>
<td>AWS / Docker / Kubernetes CI/CD</td>
</tr>

<tr>
<td><strong>Job Name</strong></td>
<td>${env.JOB_NAME}</td>
</tr>

<tr style="background:#f9fafb;">
<td><strong>Build Number</strong></td>
<td>#${env.BUILD_NUMBER}</td>
</tr>

<tr>
<td><strong>Image Tag</strong></td>
<td>${env.BUILD_NUMBER}</td>
</tr>

<tr style="background:#f9fafb;">
<td><strong>Execution Time</strong></td>
<td>${currentBuild.durationString}</td>
</tr>

<tr>
<td><strong>Triggered By</strong></td>
<td>${currentBuild.getBuildCauses()[0].shortDescription}</td>
</tr>

</table>
</td>
</tr>

<!-- BUTTON -->
<tr>
<td align="center" style="padding-bottom:30px;">
<a href="${env.BUILD_URL}" 
style="background:#1e40af;color:white;padding:12px 30px;text-decoration:none;border-radius:6px;font-weight:bold;display:inline-block;">
🔎 View Build Details
</a>
</td>
</tr>

<!-- FOOTER -->
<tr>
<td style="background:#f3f4f6;padding:20px;text-align:center;font-size:12px;color:#6b7280;">
<p style="margin:0;">Automated DevOps Pipeline</p>
<p style="margin:5px 0 0 0;">👩‍💻 Souhir | Cloud & DevOps Engineer</p>
</td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>
"""
    )
}
